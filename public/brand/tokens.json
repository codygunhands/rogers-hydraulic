{
  "$schema": "https://schemas.rogershydraulic.com/tokens.json",
  "name": "Rogers Hydraulic & Equipment Services — Brand Tokens",
  "version": "1.0.0",
  "description": "Portable design tokens for designers, sign shops, and print vendors. Mirrors src/config/brand.ts.",
  "color": {
    "graphite": { "value": "#1E2329", "role": "Primary dark — trucks, uniforms, page background" },
    "graphite-900": { "value": "#14181C", "role": "Deepest plate / near-black" },
    "graphite-700": { "value": "#282E36", "role": "Raised surface / card on dark" },
    "graphite-600": { "value": "#333A44", "role": "Border on dark" },
    "graphite-500": { "value": "#3F4752", "role": "Hairline / muted border" },
    "hivis-lime": { "value": "#D3FF00", "role": "LEAD accent — CTAs, truck stripes, icon strokes (use sparingly)" },
    "hivis-lime-dark": { "value": "#B8E000", "role": "Lime hover / pressed" },
    "signal-amber": { "value": "#F79A1B", "role": "SECONDARY — caution / warning / after-hours" },
    "white-smoke": { "value": "#F4F4F1", "role": "Light background / body text on dark" },
    "steel": { "value": "#6B7280", "role": "Secondary text / muted labels" }
  },
  "typography": {
    "heading": { "family": "Barlow Condensed", "weights": [600, 700, 800], "case": "UPPERCASE for display", "role": "Display, headings, truck wordmark, phone numerals" },
    "heading-fallback": { "family": "Oswald", "role": "System fallback for condensed display" },
    "body": { "family": "Inter", "weights": [400, 500, 600, 700], "role": "Body copy, UI, forms" }
  },
  "radius": { "sharp": "2px", "default": "4px", "badge": "8px" },
  "stroke": { "hairline": "1px", "rule": "3px", "heavy": "6px" },
  "logo": {
    "primary": "Stencil-block wordmark + hose-coupling monogram badge",
    "tagline": "On-Site. After Hours. Back to Work.",
    "files": "See /brand/logo/*.svg"
  },
  "do": [
    "Simple line/coupling geometry",
    "Thick strokes, sharp corners",
    "Giant readable phone number",
    "Graphite + lime, high contrast"
  ],
  "dont": [
    "No shields or crest badges",
    "No Texas outline, stars, or flags",
    "No crossed wrenches or gears clip-art",
    "No mascots or cowboy/western styling",
    "No chrome bevels or distressed sports fonts"
  ]
}
